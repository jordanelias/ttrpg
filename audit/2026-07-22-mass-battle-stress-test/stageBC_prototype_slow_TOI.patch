+    off_b_plain = _cellbox_corners(_bb0, use_reach=False)
+    off_a_plain = _cellbox_corners(_ba0, use_reach=False)  # a plain, vs b extended
+    off_b_reach = _cellbox_corners(_bb0, use_reach=True)
+    dar, dac = prop_a[0] - start_a[0], prop_a[1] - start_a[1]
+    dbr, dbc = prop_b[0] - start_b[0], prop_b[1] - start_b[1]
+
+    def _touch(s):
+        ar = start_a[0] + rho_a * s * dar
+        ac = start_a[1] + rho_a * s * dac
+        br = start_b[0] + rho_b * s * dbr
+        bc = start_b[1] + rho_b * s * dbc
+        ca_reach = [(ar + o[0], ac + o[1]) for o in off_a_reach]
+        cb_plain = [(br + o[0], bc + o[1]) for o in off_b_plain]
+        # a's reach meets b's body: overlap iff NO candidate axis (a's 2 + b's 2) separates
+        if not (_sat_separated(ca_reach, cb_plain, axes_a[0]) or _sat_separated(ca_reach, cb_plain, axes_a[1])
+                or _sat_separated(ca_reach, cb_plain, axes_b[0]) or _sat_separated(ca_reach, cb_plain, axes_b[1])):
+            return True
+        ca_plain = [(ar + o[0], ac + o[1]) for o in off_a_plain]
+        cb_reach = [(br + o[0], bc + o[1]) for o in off_b_reach]
+        return not (_sat_separated(ca_plain, cb_reach, axes_a[0]) or _sat_separated(ca_plain, cb_reach, axes_a[1])
+                    or _sat_separated(ca_plain, cb_reach, axes_b[0]) or _sat_separated(ca_plain, cb_reach, axes_b[1]))
+    if _touch(0.0):
+        return 0.0
+    lo = 0.0
+    hi = None
+    for i in range(1, _TOI_BOX_SCAN + 1):
+        s = i / _TOI_BOX_SCAN
+        if _touch(s):
+            hi = s
+            lo = (i - 1) / _TOI_BOX_SCAN
+            break

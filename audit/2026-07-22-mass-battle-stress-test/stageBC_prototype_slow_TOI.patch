+    for _ in range(_TOI_BOX_BISECT):
+        mid = 0.5 * (lo + hi)
+        if _touch(mid):
+            hi = mid
+        else:
+            lo = mid
+    return hi  # smallest known TRUE fraction: boxes just overlapping -> contact fires, overlap ~= 0
